{
  "extends": "@redclayradio/typescript-config/nextjs.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "auto",
    "noUncheckedIndexedAccess": false,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
